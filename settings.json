{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_claude-mem_mcp-search__smart_outline|mcp__plugin_claude-mem_mcp-search__smart_unfold|mcp__plugin_claude-mem_mcp-search__smart_search",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Banned tool: use Serena (get_symbols_overview, find_symbol) or Read/Grep instead\"}}\n'",
            "statusMessage": "Blocking banned claude-mem tool"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/destructive-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/branch-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/exfiltration-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/git-bypass-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/safe-approver.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/heuristic-approver.sh"
          }
        ]
      }
    ]
  }
}
